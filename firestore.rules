/**
 * Cafe POS — Firestore Security Rules
 *
 * Auth model:
 *  - Owner signs in via Google OAuth (owner-auth-screen.tsx)
 *  - Staff authenticate via 4-digit PIN after owner setup
 *  - The app signs clients in anonymously for the /order (QR self-serve) route
 *  - All data lives under /venues/{venueId} — scoped per business
 *
 * Security levels:
 *  ① Owner (Google Auth) — full read/write on their venue
 *  ② Staff (anonymous auth, post-PIN) — read/write on their venue's operational data  
 *  ③ Customer (unauthenticated) — can ONLY write new customerOrders (QR self-serve)
 *  ④ Everyone else — denied
 *
 * Scaling note:
 *  To add multi-staff role enforcement in future, attach a Custom Claim:
 *  request.auth.token.role == 'manager' | 'staff'
 */
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // ── Helpers ──────────────────────────────────────────────────────────────

    function isAuthenticated() {
      // Ensure the user is authenticated and not using the anonymous provider 
      // (which is used for QR customers)
      return request.auth != null && request.auth.token.firebase.sign_in_provider != 'anonymous';
    }

    // ── Venue-scoped data ─────────────────────────────────────────────────────
    // All operational data lives under /venues/{venueId}/...
    match /venues/{venueId}/{document=**} {
      // The venueId is the Owner's Google Auth UID
      // Only the authenticated Owner of this venue, OR their staff (using the shared session), can access
      allow read, write: if isAuthenticated() && request.auth.uid == venueId;
    }

    // ── Top-level legacy collections (MVP single-venue support) ───────────────
    // These collections exist at the root level for the current MVP.
    // All require authentication.
    match /menu/{categorySlug} {
      allow read: if isAuthenticated();
      allow write: if isAuthenticated();
    }

    match /tables/{tableId} {
      allow read: if isAuthenticated();
      allow write: if isAuthenticated();
    }

    match /orders/{orderId} {
      allow read, write: if isAuthenticated();
    }

    match /order_items/{orderItemId} {
      allow read, write: if isAuthenticated();
    }

    match /kitchen_orders/{kitchenOrderId} {
      allow read, write: if isAuthenticated();
    }

    match /sales_reports/{salesReportId} {
      allow read, write: if isAuthenticated();
    }

    match /expenses/{expenseId} {
      allow read, write: if isAuthenticated();
    }

    match /settings/{settingId} {
      allow read, write: if isAuthenticated();
    }

    // ── Customer Self-Serve Orders (QR Code) ──────────────────────────────────
    // Customers scanning a QR code are NOT authenticated.
    // They can ONLY create new orders (write), not read others.
    match /customerOrders/{orderId} {
      // Any authenticated user (staff) can read and manage customer orders
      allow read, write: if isAuthenticated();
      // Unauthenticated customers can ONLY create new orders via QR scan
      allow create: if request.auth == null
        && request.resource.data.keys().hasAll(['tableId', 'status', 'createdAt', 'items'])
        && request.resource.data.status == 'pending';
    }

    // ── Whitelist — Access Control for new venue owners ────────────────────────
    // Only authenticated users can read their own whitelist entry.
    // Entries are managed exclusively by the admin (Firebase Console / Admin SDK).
    match /whitelist/{email} {
      allow read: if request.auth != null
        && request.auth.token.email != null
        && request.auth.token.email.lower() == email;
      allow write: if false; // Admin Console / Admin SDK only
    }

    // ── Deny everything else ─────────────────────────────────────────────────
    // REMOVED the catch-all rule that bypassed venue scoping.
    // Any collection not explicitly listed above is denied by default.
  }
}
