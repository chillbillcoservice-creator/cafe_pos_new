/**
 * Cafe POS — Firestore Security Rules (Production Hardened)
 *
 * Auth model:
 *  - Owner signs in via Google OAuth (owner-auth-screen.tsx)
 *  - Staff authenticate via 4-digit PIN after owner setup
 *  - The app signs clients in anonymously for the /order (QR self-serve) route
 *  - All data lives under /venues/{venueId} — scoped per business
 *
 * Security levels:
 *  ① Owner (Google Auth, uid == venueId) — full read/write on their venue
 *  ② Staff (Google Auth) — read/write on operational data
 *  ③ Customer (unauthenticated) — can ONLY write new customerOrders (QR self-serve)
 *  ④ Everyone else — denied
 */
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // ── Helpers ──────────────────────────────────────────────────────────────

    // True for any non-anonymous authenticated user
    function isAuthenticated() {
      return request.auth != null
        && request.auth.token.firebase.sign_in_provider != 'anonymous';
    }

    // True only for the venue owner (their Google UID == the venueId)
    function isOwner(venueId) {
      return isAuthenticated() && request.auth.uid == venueId;
    }

    // ── Primary data path: /venues/{venueId}/... ──────────────────────────────
    // This is the secure path. Only the owner whose UID matches venueId can access.
    match /venues/{venueId}/{document=**} {
      allow read, write: if isOwner(venueId);
    }

    // ── Top-level legacy collections (MVP single-venue) ───────────────────────
    // These exist for the current single-venue MVP. Access requires authentication.

    match /menu/{categorySlug} {
      allow read: if isAuthenticated();
      allow write: if isAuthenticated();
    }

    match /tables/{tableId} {
      allow read: if isAuthenticated();
      allow write: if isAuthenticated();
    }

    match /orders/{orderId} {
      allow read, write: if isAuthenticated();
    }

    match /order_items/{orderItemId} {
      allow read, write: if isAuthenticated();
    }

    match /kitchen_orders/{kitchenOrderId} {
      allow read, write: if isAuthenticated();
    }

    match /sales_reports/{salesReportId} {
      allow read, write: if isAuthenticated();
    }

    match /expenses/{expenseId} {
      allow read, write: if isAuthenticated();
    }

    match /settings/{settingId} {
      allow read, write: if isAuthenticated();
    }

    // ── Customer Self-Serve Orders (QR Code) ──────────────────────────────────
    // Customers scanning a QR code are NOT authenticated.
    // They can ONLY create new orders, not read others.
    match /customerOrders/{orderId} {
      // Authenticated staff can fully manage orders
      allow read, write: if isAuthenticated();

      // Unauthenticated QR customers can only CREATE with valid required fields
      allow create: if request.auth == null
        && request.resource.data.keys().hasAll(['tableId', 'status', 'createdAt', 'items'])
        && request.resource.data.status == 'pending'
        && request.resource.data.items.size() > 0
        && request.resource.data.items.size() <= 50;
    }

    // ── Whitelist — Access Control for new venue owners ────────────────────────
    // Users can only read their OWN whitelist entry (to check if they're approved).
    // Only Firebase Admin SDK / Console can write entries.
    match /whitelist/{email} {
      allow read: if request.auth != null
        && request.auth.token.email != null
        && request.auth.token.email.lower() == email;
      allow write: if false; // Admin SDK / Firebase Console only
    }

    // ── Deny everything else ──────────────────────────────────────────────────
    // Any collection not explicitly listed above is denied by default in Firestore.
  }
}
